{
  "name": "@maneko/eslint-config",
  "type": "module",
  "version": "1.1.2",
  "packageManager": "pnpm@10.18.3",
  "description": "Maneko Group's ESLint config",
  "author": "Maneko Group",
  "license": "MIT",
  "homepage": "https://github.com/maneko-group/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maneko-group/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/maneko-group/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "dev": "eslint-config-inspector --config eslint.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": "^9.10.0 || ^10.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "eslint-flat-config-utils": "^3.0.1",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.4.2",
    "@maneko/prettier-config": "^1.0.0",
    "bumpp": "^10.3.1",
    "eslint": "^10.0.2",
    "lint-staged": "^16.2.4",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
