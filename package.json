{
  "name": "@maneko/eslint-config",
  "type": "module",
  "version": "0.1.3",
  "packageManager": "pnpm@10.18.3",
  "description": "Maneko Group's ESLint config",
  "author": "Maneko Group",
  "license": "MIT",
  "homepage": "https://github.com/maneko-group/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maneko-group/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/maneko-group/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "format": "prettier --write \"*.js\"",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector",
    "prepare": "husky"
  },
  "peerDependencies": {
    "eslint": "^9.38.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "eslint-flat-config-utils": "^3.0.1"
  },
  "devDependencies": {
    "@maneko/prettier-config": "^1.0.0",
    "bumpp": "^10.3.1",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
