{
  "name": "@maneko/eslint-config",
  "type": "module",
  "version": "1.1.3",
  "packageManager": "pnpm@10.18.3",
  "description": "Maneko Group's ESLint config",
  "author": "Maneko Group",
  "license": "MIT",
  "homepage": "https://github.com/maneko-group/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maneko-group/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/maneko-group/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "dev": "eslint-config-inspector --config eslint.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": "^10.0.3"
  },
  "dependencies": {
    "@antfu/eslint-config": "catalog:prod",
    "eslint-flat-config-utils": "catalog:prod",
    "jiti": "catalog:prod"
  },
  "devDependencies": {
    "@eslint/config-inspector": "catalog:dev",
    "@maneko/prettier-config": "catalog:dev",
    "bumpp": "catalog:dev",
    "eslint": "catalog:dev",
    "lint-staged": "catalog:dev",
    "prettier": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
